$start = (Get-Date).AddDays(-30)
$end = Get-Date

$usage = Get-AzConsumptionUsageDetail -StartDate $start -EndDate $end

$costTable = $usage | Group-Object ResourceGroupName | ForEach-Object {
    [PSCustomObject]@{
        ResourceGroup = $_.Name
        Cost = ($_.Group | Measure-Object PretaxCost -Sum).Sum
    }
}

